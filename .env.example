# Generate a long random value for production.
SESSION_SECRET=replace-with-a-long-random-secret

# Gmail / Google Workspace SMTP (recommended for this project).
# Enable two-step verification and create a Google App Password.
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-account@your-domain.co.il
SMTP_APP_PASSWORD=replace-with-google-app-password
SMTP_FROM=Seminar System <your-account@your-domain.co.il>
APP_URL=https://your-app-domain.co.il

# Optional Resend alternative
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM=Seminar System <updates@your-verified-domain.co.il>

# Explicit testing mode: sends every notification only to this address.
EMAIL_TEST_MODE=false
NOTIFICATION_EMAIL=test@example.com

# Optional cloud persistence
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
